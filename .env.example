# Dungeon Master — environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.
#
# In production these are passed via EnvironmentFile= in the systemd unit
# (deploy/dungeon-master.service). The defaults in app/config.py are
# suitable for local development only.

# --- Required in production ---

# URL of your vLLM endpoint (OpenAI-compatible API)
VLLM_BASE_URL=http://YOUR_AI_SERVER:8000

# URL of your FLUX.1 image generation endpoint
FLUX_BASE_URL=http://YOUR_AI_SERVER:11437

# Secret used to sign session cookies and invite tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Rotating this invalidates all active sessions and outstanding invite codes.
SESSION_SECRET=change-me-generate-a-real-secret

# --- Optional ---

# Filesystem path to the SQLite database (default: /var/lib/dungeon-master/dm.db)
# DB_PATH=/var/lib/dungeon-master/dm.db

# Directory for generated images (default: /var/lib/dungeon-master/images)
# IMAGE_STORAGE_PATH=/var/lib/dungeon-master/images

# Redis connection URL (default: redis://127.0.0.1:6379/0)
# REDIS_URL=redis://127.0.0.1:6379/0

# OpenAI-compatible embedding endpoint. When unset, the local
# sentence-transformers backend is used (slower but no extra service needed).
# EMBEDDING_BASE_URL=http://YOUR_AI_SERVER:11436/v1
# EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
